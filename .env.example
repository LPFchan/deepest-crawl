# Optional local configuration for deepest-crawl.
# Copy to .env and adjust for your machine. .env is gitignored.

# OpenAI-compatible model endpoint used by deepest/brain.py.
DEEPEST_BRAIN_ENDPOINT=http://127.0.0.1:8765/v1/chat/completions

# Model name or local model path. The service helper can also choose from its
# built-in registry.
DEEPEST_BRAIN_MODEL=froggeric/Qwen3.6-27B-Uncensored-Heretic-v2-MLX-4bit

# Set to 0 when using a text-only model.
DEEPEST_BRAIN_VISION=1

# Let the dashboard/runner start local dependencies when they are missing.
DEEPEST_BRAIN_AUTOSTART=1
DEEPEST_CHROME_AUTOSTART=1

# Autostart settings for mlx_vlm.server.
DEEPEST_BRAIN_HOST=127.0.0.1
DEEPEST_BRAIN_PORT=8765
DEEPEST_BRAIN_WAIT=180

# Chrome transport startup settings.
DEEPEST_CHROME_APP=Google Chrome
DEEPEST_CHROME_WAIT=60
DEEPEST_CHROME_PROBE_TIMEOUT=2.5
DEEPEST_CHROME_COMMAND_TIMEOUT_SECONDS=20

# Optional SQLite link-cache adapter paths.
# DEEPEST_LINK_CACHE_DB=/path/to/cache.db
# DEEPEST_LINKS_OUT=inputs/links.json

# Optional alternate local model paths used by the included helper scripts.
DEEPEST_HOLO_MODEL=$HOME/models/Holo-3.1-9B-mlx
